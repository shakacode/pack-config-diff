#!/usr/bin/env bash
# Lint all files changed on this branch compared to origin/main.
# Intended for pre-push hook to catch issues before they hit CI.

set -euo pipefail

base_branch="${1:-origin/main}"

# Get all changed files on this branch vs the base
changed_files=()
while IFS= read -r -d '' file; do
  changed_files+=("$file")
done < <(git diff --name-only --diff-filter=ACMR -z "$base_branch"...HEAD)

if [ "${#changed_files[@]}" -eq 0 ]; then
  echo "No changed files to lint."
  exit 0
fi

js_files=()
format_files=()
for file in "${changed_files[@]}"; do
  case "$file" in
    *.js|*.ts|*.mjs)
      js_files+=("$file")
      format_files+=("$file")
      ;;
    *.json|*.md|*.yml|*.yaml)
      format_files+=("$file")
      ;;
  esac
done

errors=0

if [ "${#js_files[@]}" -gt 0 ]; then
  echo "Running ESLint on changed files..."
  npx eslint -- "${js_files[@]}" || errors=$((errors + 1))
fi

if [ "${#format_files[@]}" -gt 0 ]; then
  echo "Running Prettier check on changed files..."
  npx prettier --check -- "${format_files[@]}" || errors=$((errors + 1))
fi

if [ "$errors" -gt 0 ]; then
  echo ""
  echo "Lint errors found. Run 'npm run lint:fix' to auto-fix."
  exit 1
fi

echo "All lint checks passed."
